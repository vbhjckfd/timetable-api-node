{
  "name": "timetable-api-node",
  "version": "1.1.0",
  "description": "Lviv (Ukraine) public transport REST API and read-only Model Context Protocol (MCP) server: stops, timetables, routes, live vehicle positions, GTFS/GTFS-RT. No API key required.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "timetable-mcp": "./mcp/stdio.js"
  },
  "files": [
    "mcp/stdio.js",
    "mcp/config.json",
    "INTEGRATION.md"
  ],
  "homepage": "https://lad.lviv.ua",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbhjckfd/timetable-api-node.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lviv",
    "transit",
    "gtfs",
    "timetable",
    "public-transport",
    "ukraine",
    "api"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.52.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4",
    "express": "^5.2.1",
    "gtfs": "^4.18.5",
    "gtfs-realtime-bindings": "^1.1.1",
    "lokijs": "^1.5.12",
    "npm-config": "^0.2.0",
    "protobufjs": ">=8.2.0",
    "public-google-sheets-parser": "^1.3.2",
    "tar": ">=7.5.15",
    "zod": "^4.4.3"
  },
  "scripts": {
    "import": "node gtfs-import.js",
    "import-slim": "node gtfs-import-slim.js",
    "start": "node index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "vbhjckfd@gmail.com",
  "license": "WTFPL",
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
